local speeds = 1
local flying = false
local noclips = false
local speaker = game:GetService("Players").LocalPlayer
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local function toggleFly(state)
    flying = state
    onof.Text = flying and "FLY: ON" or "FLY: OFF"
    onof.BackgroundColor3 = flying and Color3.fromRGB(40, 140, 40) or Color3.fromRGB(140, 40, 40)
    
    local char = speaker.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    
    if flying then
        char.Animate.Disabled = true
        for _, v in next, hum:GetPlayingAnimationTracks() do v:Stop() end
        hum.PlatformStand = true
        
        task.spawn(function()
            local bg = Instance.new("BodyGyro", root)
            local bv = Instance.new("BodyVelocity", root)
            bg.P = 9e4
            bg.maxTorque = Vector3.new(9e9, 9e9, 9e9)
            bv.maxForce = Vector3.new(9e9, 9e9, 9e9)
            
            while flying and char.Parent and hum.Health > 0 do
                local cam = workspace.CurrentCamera.CFrame
                local direction = Vector3.new(0, 0, 0)
                
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then direction = direction + cam.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then direction = direction - cam.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then direction = direction - cam.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then direction = direction + cam.RightVector end
                
                if direction.Magnitude > 0 then direction = direction.Unit end
                
                bg.CFrame = cam
                bv.velocity = direction * (speeds * 50)
                RunService.RenderStepped:Wait()
            end
            bg:Destroy()
            bv:Destroy()
            if hum then hum.PlatformStand = false end
            if char:FindFirstChild("Animate") then char.Animate.Disabled = false end
        end)
    else
        if hum then hum.PlatformStand = false end
        if char:FindFirstChild("Animate") then char.Animate.Disabled = false end
    end
end

onof.MouseButton1Down:Connect(function()
    toggleFly(not flying)
end)

noclipBtn.MouseButton1Down:Connect(function()
    noclips = not noclips
    noclipBtn.Text = noclips and "NOCLIP: ON" or "NOCLIP: OFF"
    noclipBtn.BackgroundColor3 = noclips and Color3.fromRGB(70, 70, 160) or Color3.fromRGB(40, 40, 70)
    
    if noclips and not flying then
        toggleFly(true)
    end
    
    task.spawn(function()
        while noclips do
            local char = speaker.Character
            if char then
                for _, v in pairs(char:GetDescendants()) do
                    if v:IsA("BasePart") and v.CanCollide then
                        v.CanCollide = false
                    end
                end
            end
            RunService.Stepped:Wait()
        end
    end)
end)

