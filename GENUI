------------------------------------------------------------------------
-- Logic Architecture: Parsing Target
------------------------------------------------------------------------
local function parseTargetPlayer(text)
    local query = string.lower(text)
    if query == "" then return nil end
    for _, v in ipairs(Players:GetPlayers()) do
        if string.sub(string.lower(v.Name), 1, #query) == query or string.sub(string.lower(v.DisplayName), 1, #query) == query then
            return v
        end
    end
    return nil
end


------------------------------------------------------------------------
-- Logic Architecture: Teleport & Added Features
------------------------------------------------------------------------
local function teleportExecution()
    local target = parseTargetPlayer(PlayerTextBox.Text)
    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        local myChar = localPlayer.Character
        if myChar and myChar:FindFirstChild("HumanoidRootPart") and myChar:FindFirstChildOfClass("Humanoid") then
            myChar.Humanoid.Sit = false
            task.wait(0.01)
            myChar.HumanoidRootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            myChar.HumanoidRootPart.CFrame = target.Character.HumanoidRootPart.CFrame * CFrame.new(0, 3, 0)
        end
    end
end

TeleportButton.MouseButton1Click:Connect(teleportExecution)
PlayerTextBox.FocusLost:Connect(function(enter)
    if enter then teleportExecution() end
end)

