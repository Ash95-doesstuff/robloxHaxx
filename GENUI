------------------------------------------------------------------------
-- Logic Architecture: Tab Toggles
------------------------------------------------------------------------
local function updateTabs(activeBtn, activePage)
    local buttons = {FlyTabBtn, MoveTabBtn, TpTabBtn, FunTabBtn}
    local pages = {FlyPageFrame, MovePageFrame, TpPageFrame, FunPageFrame}
    
    for i, btn in ipairs(buttons) do
        if btn == activeBtn then
            btn.BackgroundTransparency = 0
            btn.BackgroundColor3 = Color3.fromRGB(50, 50, 58)
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
            pages[i].Visible = true
        else
            btn.BackgroundTransparency = 1
            btn.TextColor3 = Color3.fromRGB(150, 150, 158)
            pages[i].Visible = false
        end
    end
end

FlyTabBtn.MouseButton1Click:Connect(function() updateTabs(FlyTabBtn, FlyPageFrame) end)
MoveTabBtn.MouseButton1Click:Connect(function() updateTabs(MoveTabBtn, MovePageFrame) end)
TpTabBtn.MouseButton1Click:Connect(function() updateTabs(TpTabBtn, TpPageFrame) end)
FunTabBtn.MouseButton1Click:Connect(function() updateTabs(FunTabBtn, FunPageFrame) end)


------------------------------------------------------------------------
-- Logic Architecture: Flight Execution
------------------------------------------------------------------------
local function startFlight()
    local char = localPlayer.Character
    if not char then return end

    local humanoid = char:FindFirstChildOfClass("Humanoid")
    local rootPart = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
    if not rootPart or not humanoid then return end

    local bg = Instance.new("BodyGyro", rootPart)
    bg.P = 9e4
    bg.maxTorque = Vector3.new(9e9, 9e9, 9e9)
    bg.cframe = rootPart.CFrame

    local bv = Instance.new("BodyVelocity", rootPart)
    bv.velocity = Vector3.new(0, 0.1, 0)
    bv.maxForce = Vector3.new(9e9, 9e9, 9e9)

    humanoid.PlatformStand = true

    task.spawn(function()
        while nowe and localPlayer.Character and humanoid.Health > 0 do
            local camera = workspace.CurrentCamera
            if not camera then break end

            local cf = camera.CFrame
            local moveDir = Vector3.new(0, 0, 0)

            if currentKeys.f == 1 then moveDir = moveDir + cf.LookVector end
            if currentKeys.b == 1 then moveDir = moveDir - cf.LookVector end
            if currentKeys.r == 1 then moveDir = moveDir + cf.RightVector end
            if currentKeys.l == 1 then moveDir = moveDir - cf.RightVector end

            if moveDir.Magnitude > 0 then
                bv.velocity = moveDir.Unit * (flySpeed * 35)
            else
                bv.velocity = Vector3.new(0, 0, 0)
            end

            bg.cframe = cf
            RunService.RenderStepped:Wait()
        end

        bg:Destroy()
        bv:Destroy()
        humanoid.PlatformStand = false
    end)
end

UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.W then currentKeys.f = 1 end
    if input.KeyCode == Enum.KeyCode.S then currentKeys.b = 1 end
    if input.KeyCode == Enum.KeyCode.D then currentKeys.r = 1 end
    if input.KeyCode == Enum.KeyCode.A then currentKeys.l = 1 end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.W then currentKeys.f = 0 end
    if input.KeyCode == Enum.KeyCode.S then currentKeys.b = 0 end
    if input.KeyCode == Enum.KeyCode.D then currentKeys.r = 0 end
